# External plugins (fetched at build time from external-plugins.json).
# In-tree plugins (default-policy, header-tier-router) are tracked.
# External plugins materialize here only during builds; never committed.
# Per-plugin ignore rules below list each external plugin currently
# referenced in external-plugins.json. Add a new entry here when you add
# a new external plugin.

# Local override for external-plugins.json. Lets operators add private
# plugin repos without committing private URLs to the public repo.
# Copy external-plugins.local.example.json to external-plugins.local.json
# and edit.
external-plugins.local.json

# Materialized from config.example.json at build time by
# scripts/sync-config.mjs. The example file is the source of truth;
# this file is gitignored so the build always regenerates it from the
# canonical example. To override defaults permanently, edit
# config.example.json. sync-config.mjs unconditionally overwrites this
# file on every build, so manual edits here do not survive.
manifest-plugins.config.json

