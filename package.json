{
  "name": "@josiahsiegel/manifest-plugins",
  "version": "0.1.0",
  "description": "Fork-only plugins for Manifest — applied post-sync via npm run apply. The plugin host is injected into mnfst/manifest by `src/host/apply.ts` so the fork can install/request-modify Anthropic (and future) providers without re-syncing overlay patches.",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/index.js",
    "dist/index.d.ts",
    "dist/host",
    "dist/plugins",
    "dist/overlays/mvp",
    "dist/admin",
    "src/host/snippet.ts",
    "src/host/apply.ts"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && find dist -type f \\( -name '*.spec.js' -o -name '*.spec.d.ts' -o -name '*.spec.js.map' -o -name '*.spec.d.ts.map' \\) -delete && node scripts/fetch-external-plugins.mjs && node scripts/filter-plugins.mjs && node scripts/vendor-hash-wasm.mjs && node scripts/build-overlay.mjs && node scripts/build-admin-ui.mjs",
    "build:overlay": "node scripts/build-overlay.mjs",
    "fetch:external-plugins": "node scripts/fetch-external-plugins.mjs",
    "clean": "rimraf dist coverage .tsbuildinfo",
    "lint": "eslint 'src/**/*.ts' 'tests/**/*.ts'",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "apply": "tsx src/host/cli.ts",
    "verify": "tsx src/host/verify.ts",
    "new-plugin": "node scripts/new-plugin.mjs",
    "plugins:list": "node scripts/plugins-cli.mjs list",
    "plugins:enable": "node scripts/plugins-cli.mjs enable",
    "plugins:disable": "node scripts/plugins-cli.mjs disable",
    "plugins:reset": "node scripts/plugins-cli.mjs reset"
  },
  "dependencies": {
    "express": "^4.21.0",
    "hash-wasm": "^4.12.0"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.0.0",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^7.7.0",
    "@typescript-eslint/parser": "^7.7.0",
    "esbuild": "^0.24.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.4.1",
    "jsdom": "^25.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "rimraf": "^5.0.5",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.2",
    "tsx": "^4.7.2",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "manifest",
    "mnfst",
    "plugin",
    "anthropic",
    "oauth",
    "billing-header"
  ],
  "license": "MIT"
}
